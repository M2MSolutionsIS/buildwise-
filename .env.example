# BuildWise Environment Variables
# Copy to .env and fill in values

# Database
DATABASE_URL=postgresql+asyncpg://buildwise:buildwise@localhost:5432/buildwise
POSTGRES_USER=buildwise
POSTGRES_PASSWORD=buildwise
POSTGRES_DB=buildwise

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Auth
JWT_SECRET_KEY=CHANGE_ME_TO_RANDOM_STRING
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# App
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# Frontend
VITE_API_URL=http://localhost:8000/api/v1

# Email (Resend)
RESEND_API_KEY=re_CHANGE_ME

# Prototype (P1, P2, P3)
DEFAULT_PROTOTYPE=P1
