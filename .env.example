# ── BuildWise Environment Variables ────────────────────────────
# Copy to .env and fill in values:  cp .env.example .env

# ── PostgreSQL ─────────────────────────────────────────────────
POSTGRES_USER=buildwise
POSTGRES_PASSWORD=buildwise
POSTGRES_DB=buildwise
# Used by the backend (asyncpg driver, points to docker service "db")
DATABASE_URL=postgresql+asyncpg://buildwise:buildwise@db:5432/buildwise

# ── Redis ──────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── JWT Auth ───────────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_TO_RANDOM_STRING
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── App ────────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# ── Frontend ───────────────────────────────────────────────────
VITE_API_URL=/api/v1

# ── Email (Resend) ─────────────────────────────────────────────
RESEND_API_KEY=re_CHANGE_ME

# ── Prototype flag (P1 = BuildWise TRL5, P2 = BAHM Op., P3 = M2M Lite)
DEFAULT_PROTOTYPE=P1
